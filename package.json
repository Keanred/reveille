{
  "name": "reveille",
  "version": "0.1.0",
  "description": "A terminal dashboard that aggregates live data sources into one Ink-rendered view.",
  "type": "module",
  "engines": {
    "node": ">=20.12.0"
  },
  "bin": {
    "reveille": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "files": [
    "dist",
    "config.example.toml",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx --env-file-if-exists=.env src/cli.tsx",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file-if-exists=.env dist/cli.js",
    "login:google": "tsx --env-file-if-exists=.env src/cli.tsx login google",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "ink": "^5.0.1",
    "react": "^18.3.1",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.3.3",
    "tsx": "^4.16.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.5"
  }
}
